datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TipoPlazo {
  DIA
  SEMANA
  MES
}

enum TipoPrestamo {
  FIJO
  SOBRE_SALDO
}

model User {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String
  role      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  prestamos Prestamo[]
  gastos    Gasto[]
  rutas     Ruta[]    @relation("RutaCobrador")
  clientes  Cliente[] @relation("ClienteUsuario")
  auditLogs AuditLog[]

  @@map("User")
}

model Cliente {
  id                 Int       @id @default(autoincrement())
  tipoIdentificacion String
  identificacion     String    @unique
  nombres            String
  apellidos          String
  direccion          String
  telefono           String
  sectorId           Int
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  correo             String
  usuarioId          Int?      // FK indica ON DELETE SET NULL
  fechaNacimiento    DateTime? @db.Date

  // Relaciones
  sector   Ruta   @relation(fields: [sectorId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  usuario  User?  @relation("ClienteUsuario", fields: [usuarioId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  prestamos Prestamo[]

  rutas    ClienteRuta[] // Relación M:N con Ruta

  @@map("Cliente")
}

model Prestamo {
  id           Int          @id @default(autoincrement())
  codigo       String       @unique
  monto        Decimal      @db.Decimal(12, 2)
  tasa         Float
  plazoDias    Int
  tipoPlazo    TipoPlazo    @default(DIA)
  fechaInicio  DateTime     @db.Timestamp(3)
  estadoId     Int
  clienteId    Int
  usuarioId    Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tipoPrestamo TipoPrestamo @default(FIJO)

  // Relaciones
  estado  Estado  @relation(fields: [estadoId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  cliente Cliente @relation(fields: [clienteId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  usuario User    @relation(fields: [usuarioId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  pagos   Pago[]

  @@map("Prestamo")
}

model Pago {
  id         Int      @id @default(autoincrement())
  prestamoId Int
  fecha      DateTime @db.Timestamp(3)
  monto      Decimal  @db.Decimal(12, 2)
  estadoId   Int

  // Relaciones
  prestamo Prestamo @relation(fields: [prestamoId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  estado   Estado   @relation(fields: [estadoId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  @@map("Pago")
}

model Estado {
  id     Int    @id @default(autoincrement())
  nombre String @unique

  // Relaciones
  prestamos Prestamo[]
  pagos     Pago[]

  @@map("Estado")
}


model Gasto {
  id          Int      @id @default(autoincrement())
  descripcion String
  monto       Decimal  @db.Decimal(12, 2)
  fecha       DateTime @db.Timestamp(3)
  categoria   String
  active      Boolean  @default(true)
  usuarioId   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  usuario User @relation(fields: [usuarioId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  @@map("Gasto")
}

model Ruta {
  id        Int      @id @default(autoincrement())
  nombre    String
  sector    String
  cobradorId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  cobrador User     @relation("RutaCobrador", fields: [cobradorId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  sectores Cliente[] // Relación inversa para Cliente.sector
  // ...existing code...

  clientes ClienteRuta[] // Relación M:N con Cliente

  @@map("Ruta")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  entity    String
  entityId  Int
  details   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  @@map("AuditLog")
}

model Empresa {
  id         Int      @id @default(autoincrement())
  nombre     String   @db.VarChar(255)
  ruc        String   @unique @db.VarChar(50)
  direccion  String   @db.VarChar(255)
  telefono   String   @db.VarChar(50)
  correo     String   @db.VarChar(255)
  logoUrl    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  divisa     String   @default("USD") @db.VarChar(10)
  codigoPais String   @default("CO")  @db.VarChar(10)

  @@map("Empresa")
}

model ClienteRuta {
  clienteId Int @map("A")
  rutaId    Int @map("B")

  cliente   Cliente @relation(fields: [clienteId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  ruta      Ruta    @relation(fields: [rutaId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@unique([clienteId, rutaId], map: "_ClienteToRuta_AB_unique")
  @@index([rutaId], map: "_ClienteToRuta_B_index")
  @@map("_ClienteToRuta")
}


