datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TipoPlazo {
  DIA
  SEMANA
  MES
}

enum TipoPrestamo {
  FIJO
  SOBRE_SALDO
}

enum TipoGasto {
  OPERATIVO       // gastos de operación diaria
  PERSONAL        // salarios y comisiones
  ADMINISTRATIVO  // papelería, servicios, etc.
  FINANCIERO      // costos financieros, intereses pagados
  JURIDICO        // honorarios legales, cobro judicial
  OTROS
}

model User {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String
  role      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  prestamos Prestamo[]
  gastos    Gasto[]
  rutas     Ruta[]    @relation("RutaCobrador")
  clientes  Cliente[] @relation("ClienteUsuario")
  auditLogs AuditLog[]
  ventas    Venta[]

  @@map("User")
}

model Cliente {
  id                 Int       @id @default(autoincrement())
  tipoIdentificacion String
  identificacion     String    @unique
  nombres            String
  apellidos          String
  direccion          String
  telefono           String
  sectorId           Int
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  correo             String
  usuarioId          Int?      // FK indica ON DELETE SET NULL
  fechaNacimiento    DateTime? @db.Date

  // Relaciones
  sector    Ruta    @relation(fields: [sectorId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  usuario   User?   @relation("ClienteUsuario", fields: [usuarioId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  prestamos Prestamo[]
  ventas    Venta[]

  rutas    ClienteRuta[] // Relación M:N con Ruta

  @@map("Cliente")
}

model Prestamo {
  id                Int          @id @default(autoincrement())
  codigo            String       @unique
  monto             Decimal      @db.Decimal(12, 2)
  tasa              Float
  plazoDias         Int
  tipoPlazo         TipoPlazo    @default(DIA)
  fechaInicio       DateTime     @db.Timestamp(3)
  estadoId          Int
  clienteId         Int
  usuarioId         Int
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  tipoPrestamo      TipoPrestamo @default(FIJO)
  // ── Campos contables ─────────────────────────────────────────────────────
  totalConIntereses Decimal?     @db.Decimal(12, 2) // capital + interés total esperado

  // Relaciones
  estado  Estado  @relation(fields: [estadoId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  cliente Cliente @relation(fields: [clienteId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  usuario User    @relation(fields: [usuarioId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  pagos   Pago[]

  @@map("Prestamo")
}

model Pago {
  id             Int      @id @default(autoincrement())
  prestamoId     Int
  fecha          DateTime @db.Timestamp(3)
  monto          Decimal  @db.Decimal(12, 2)
  estadoId       Int
  // ── Campos contables ───────────────────────────────────────────────────
  capitalAbonado Decimal? @db.Decimal(12, 2)  // porción que reduce el saldo del capital
  interesAbonado Decimal? @db.Decimal(12, 2)  // porción que corresponde a intereses
  saldoCapital   Decimal? @db.Decimal(12, 2)  // saldo pendiente de capital tras este pago

  // Relaciones
  prestamo Prestamo @relation(fields: [prestamoId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  estado   Estado   @relation(fields: [estadoId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  @@map("Pago")
}

model Estado {
  id     Int    @id @default(autoincrement())
  nombre String @unique

  // Relaciones
  prestamos  Prestamo[]
  pagos      Pago[]
  ventas     Venta[]
  cuotasVenta CuotaVenta[]

  @@map("Estado")
}


model Gasto {
  id          Int       @id @default(autoincrement())
  descripcion String
  monto       Decimal   @db.Decimal(12, 2)
  fecha       DateTime  @db.Timestamp(3)
  categoria   TipoGasto @default(OTROS)
  active      Boolean  @default(true)
  usuarioId   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  usuario User @relation(fields: [usuarioId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  @@map("Gasto")
}

model Ruta {
  id        Int      @id @default(autoincrement())
  nombre    String
  sector    String
  cobradorId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  cobrador User     @relation("RutaCobrador", fields: [cobradorId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  sectores Cliente[] // Relación inversa para Cliente.sector
  // ...existing code...

  clientes ClienteRuta[] // Relación M:N con Cliente

  @@map("Ruta")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  entity    String
  entityId  Int
  details   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  @@map("AuditLog")
}

model Empresa {
  id         Int      @id @default(autoincrement())
  nombre     String   @db.VarChar(255)
  ruc        String   @unique @db.VarChar(50)
  direccion  String   @db.VarChar(255)
  telefono   String   @db.VarChar(50)
  correo     String   @db.VarChar(255)
  logoUrl    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  divisa     String   @default("USD") @db.VarChar(10)
  codigoPais String   @default("CO")  @db.VarChar(10)

  @@map("Empresa")
}

enum EstadoSuscripcion {
  ACTIVA
  VENCIDA
  CANCELADA
}

model Plan {
  id                     Int      @id @default(autoincrement())
  nombre                 String   @unique
  descripcion            String?
  caracteristicas        Json     @default("[]")  // array de strings para mostrar en UI
  maxUsuarios            Int      // -1 = ilimitado
  maxClientes            Int      // -1 = ilimitado
  maxPrestamosPorCliente Int      // -1 = ilimitado
  precio                 Decimal  @db.Decimal(10, 2)
  duracionDias           Int      @default(30)  // días de vigencia al renovar; 0 = sin vencimiento
  activo                 Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  suscripciones Suscripcion[]
  tenants       Tenant[]

  @@map("Plan")
}

model Suscripcion {
  id          Int                @id @default(autoincrement())
  tenantId    Int?               // null en esquemas de tenant (ya están aislados por schema), set en esquema principal para facturación
  planId      Int
  fechaInicio DateTime
  fechaFin    DateTime?          // null = no vence (plan gratis)
  estado      EstadoSuscripcion  @default(ACTIVA)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan    @relation(fields: [planId],   references: [id])

  @@map("Suscripcion")
}

// ─── Multi-tenancy ────────────────────────────────────────────────────────────

enum EstadoTenant {
  ACTIVO
  SUSPENDIDO
  CANCELADO
}

model Tenant {
  id          Int          @id @default(autoincrement())
  nombre      String
  email       String       @unique
  telefono    String?
  schemaName  String       @unique   // nombre del esquema PostgreSQL (ej. tenant_acme)
  planId      Int
  estado      EstadoTenant @default(ACTIVO)
  notas       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  plan          Plan          @relation(fields: [planId], references: [id])
  pagos         PagoTenant[]
  suscripciones Suscripcion[]

  @@map("Tenant")
}

model PagoTenant {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  monto      Decimal  @db.Decimal(10, 2)
  concepto   String
  fecha      DateTime @default(now())
  referencia String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@map("PagoTenant")
}

/// Transacciones de pago iniciadas a través de Wompi.
/// Se crea ANTES de abrir el widget (status=PENDING) y se actualiza
/// por el webhook cuando Wompi notifica el resultado.
model WompiTransaccion {
  id            Int       @id @default(autoincrement())
  reference     String    @unique
  planId        Int
  amountInCents Int
  currency      String    @default("COP")
  email         String
  tenantNombre  String?
  /// null hasta que el tenant sea creado tras el pago
  tenantId      Int?
  /// PENDING | APPROVED | DECLINED | VOIDED | ERROR
  status        String    @default("PENDING")
  /// ID de transacción retornado por Wompi en el webhook
  wompiId       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("WompiTransaccion")
}

model ClienteRuta {
  clienteId Int @map("A")
  rutaId    Int @map("B")

  cliente   Cliente @relation(fields: [clienteId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  ruta      Ruta    @relation(fields: [rutaId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@unique([clienteId, rutaId], map: "_ClienteToRuta_AB_unique")
  @@index([rutaId], map: "_ClienteToRuta_B_index")
  @@map("_ClienteToRuta")
}

// ─── Módulo de Mercancía ──────────────────────────────────────────────────────

model Proveedor {
  id        Int      @id @default(autoincrement())
  nombre    String
  contacto  String?
  telefono  String?
  email     String?
  direccion String?
  notas     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productos Producto[]

  @@map("Proveedor")
}

model CategoriaProducto {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  productos Producto[]

  @@map("CategoriaProducto")
}

model Producto {
  id           Int     @id @default(autoincrement())
  codigo       String  @unique
  nombre       String
  descripcion  String?
  precioCompra Decimal @db.Decimal(12, 2)
  precioVenta  Decimal @db.Decimal(12, 2)
  stock        Int     @default(0)
  stockMinimo  Int     @default(0)
  categoriaId  Int?
  proveedorId  Int?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categoria  CategoriaProducto? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  proveedor  Proveedor?         @relation(fields: [proveedorId], references: [id], onDelete: SetNull)
  itemsVenta ItemVenta[]

  @@map("Producto")
}

model Venta {
  id           Int       @id @default(autoincrement())
  codigo       String    @unique
  clienteId    Int
  usuarioId    Int
  fechaInicio  DateTime  @db.Timestamp(3)
  totalVenta   Decimal   @db.Decimal(12, 2)
  cuotaMonto   Decimal   @db.Decimal(12, 2)
  numeroCuotas Int
  tipoPlazo    TipoPlazo @default(DIA)
  estadoId     Int
  notas        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  usuario User    @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  estado  Estado  @relation(fields: [estadoId], references: [id], onDelete: Restrict)
  items   ItemVenta[]
  cuotas  CuotaVenta[]

  @@map("Venta")
}

model ItemVenta {
  id         Int     @id @default(autoincrement())
  ventaId    Int
  productoId Int
  cantidad   Int
  precioUnit Decimal @db.Decimal(12, 2)
  subtotal   Decimal @db.Decimal(12, 2)

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@map("ItemVenta")
}

model CuotaVenta {
  id          Int      @id @default(autoincrement())
  ventaId     Int
  numeroCuota Int
  fechaPago   DateTime @db.Timestamp(3)
  monto       Decimal  @db.Decimal(12, 2)
  estadoId    Int
  pagadoEn    DateTime? @db.Timestamp(3)
  createdAt   DateTime  @default(now())

  venta  Venta  @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  estado Estado @relation(fields: [estadoId], references: [id], onDelete: Restrict)

  @@map("CuotaVenta")
}


